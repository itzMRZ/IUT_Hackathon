# ── Office server (server/index.ts) ─────────────────────────────────────
PORT=3001

# ── Dashboard (src/) ─────────────────────────────────────────────────────
# Optional locally — Vite proxies /ws and /api to localhost:3001 in dev.
# REQUIRED in production when the dashboard (e.g. Vercel) and the server
# (e.g. Railway) are deployed to different hosts. See DEPLOYMENT.md.
# VITE_API_URL=https://your-server.up.railway.app
# VITE_WS_URL=wss://your-server.up.railway.app/ws

# ── Discord webhook (posts on every simulation change) ──────────────────
# Server Settings → Integrations → Webhooks → New Webhook → copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ── Discord bot (discord/bot.ts) ─────────────────────────────────────────
# Discord Developer Portal → New Application → Bot → Reset Token
DISCORD_TOKEN=your-bot-token
DISCORD_PREFIX=!
# Channel ID to post live alerts to (right-click channel → Copy Channel ID,
# requires Developer Mode enabled in Discord settings)
DISCORD_ALERT_CHANNEL_ID=

# Where the bot reaches the office server's REST + WebSocket API
API_URL=http://localhost:3001
# WS_URL=ws://localhost:3001/ws
